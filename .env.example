# Local Database config (Defaults to SQLite for instant local zero-setup execution)
# To switch to PostgreSQL, change 'provider = "sqlite"' to 'provider = "postgresql"' in prisma/schema.prisma and set your PG connection URL here.
DATABASE_URL="file:./dev.db"

# NextAuth Configurations
NEXTAUTH_SECRET="super-secret-key-replace-with-secure-key-in-production"
NEXTAUTH_URL="http://localhost:3000"

# AI Provider Configurations
# Put either your Gemini API Key or your OpenAI API Key. The application logic automatically detects and uses whichever one is provided!
GEMINI_API_KEY=""
OPENAI_API_KEY=""
